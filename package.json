{
  "name": "prox-omnipro-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c '#f97316,#38bdf8' 'npm run dev -w @prox/server' 'npm run dev -w @prox/web'",
    "build": "npm run build -w @prox/web && npm run build -w @prox/server",
    "start": "npm run start -w @prox/server",
    "test:e2e": "playwright test",
    "typecheck": "npm run typecheck -w @prox/server && npm run typecheck -w @prox/web",
    "test": "npm run test -w @prox/server",
    "eval": "npm run eval -w @prox/server",
    "ingest": "tsx scripts/ingest/cli.ts",
    "ingest:video": "tsx scripts/ingest/cli.ts",
    "extract": "python3 scripts/ingest/prepare-pdf.py",
    "extract:video": "python3 scripts/ingest/prepare-video.py"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": "22.x"
  }
}
