# Create .env from this file and paste your Anthropic API key.
ANTHROPIC_API_KEY=
# Optional locally, required on Vercel. Protects the site and all API routes.
# ARCWELL_ACCESS_PASSWORD=choose-a-long-private-password
# ARCWELL_SESSION_SECRET=generate-a-separate-random-secret
# Optional. Local development defaults to SQLite.
# ARCWELL_CHAT_STORAGE=sqlite
# ARCWELL_CHAT_STORAGE=turso
# ARCWELL_CHAT_STORAGE=disabled
# Vercel uses Turso automatically when both values are configured.
# TURSO_DATABASE_URL=libsql://database-name-organization.turso.io
# TURSO_AUTH_TOKEN=
# Photo uploads use local disk and therefore default to disabled on Vercel.
# ARCWELL_PHOTO_STORAGE=local

# Optional: override the default Claude model.
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional offline-ingestion overrides. Ingestion never runs during app startup.
# CLAUDE_INGESTION_MODEL=claude-sonnet-4-6
# CLAUDE_INGESTION_MAX_TURNS=24
# CLAUDE_INGESTION_MAX_BUDGET_USD=1.5
# CLAUDE_INGESTION_STAGE_TIMEOUT_MS=600000
# INGESTION_PYTHON=.venv-ingest/bin/python
# KNOWLEDGE_PRODUCT_ID=omnipro-220
